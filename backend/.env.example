# ═══════════════════════════════════════════════════════
# CareerOS Backend — Environment Variables
# Kopiér til .env og udfyld alle værdier før opstart.
# ═══════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────
# DEBUG=true viser /api/docs og /api/redoc
DEBUG=true

# Generer med: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-min-64-chars

# ── Supabase ─────────────────────────────────────────────
# Lokal Supabase: kør `supabase start` og brug output-nøglerne
# Cloud Supabase: hent fra https://supabase.com/dashboard → Settings → API
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Kryptering ───────────────────────────────────────────
# Bruges til at kryptere bruger-API-nøgler i databasen (AES-256 via Fernet)
# Generer med: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# ── AI Providers ─────────────────────────────────────────
# Mindst én skal udfyldes. OpenAI anbefales til Sprint 1.
# Standard model: gpt-4o (cv_agent.py + discovery_service.py)
OPENAI_API_KEY=sk-...

# Valgfri alternativer
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_BASE_URL=http://localhost:11434

# ── Stripe (valgfri — kræves ikke til Sprint 1) ──────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── CORS ─────────────────────────────────────────────────
# Kommasepareret liste over tilladte origins
# Lokal udvikling: http://localhost:3000
# Production: din frontend URL
CORS_ORIGINS=http://localhost:3000
