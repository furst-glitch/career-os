# ═══════════════════════════════════════════════════════
# CareerOS Frontend — Environment Variables
# Kopiér til .env.local og udfyld alle værdier.
# NEXT_PUBLIC_* variabler er synlige i browseren.
# ═══════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────
# Lokal Supabase: kør `supabase start` → brug API URL og anon key
# Cloud Supabase: hent fra https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Backend API ───────────────────────────────────────────
# Sæt til din backend-rod URL — /api/v1 tilføjes automatisk i koden.
# Lokal:      http://localhost:8000
# Production: https://career-os-backend-yudt.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Stripe (valgfri — kræves ikke til Sprint 1) ──────────
# Kun publishable key her (secret key hører til backend)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
